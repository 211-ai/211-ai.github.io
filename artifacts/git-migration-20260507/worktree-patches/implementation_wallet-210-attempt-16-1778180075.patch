+async function waitForWalletRecord(baseUrl: string, walletId: string, dataType: string): Promise<WalletRecord> {
+  const deadline = Date.now() + 15_000;
+  let lastRecords: WalletRecord[] = [];
+  while (Date.now() < deadline) {
+    const records = await apiJson<{ records: WalletRecord[] }>(
+      baseUrl,
+      "GET",
+      `/wallets/${walletId}/records?data_type=${encodeURIComponent(dataType)}`
+    );
+    lastRecords = records.records;
+    const record = records.records.find((item) => item.data_type === dataType);
+    if (record) return record;
+    await delay(100);
+  }
+  throw new Error(`No ${dataType} wallet record appeared. Last records: ${JSON.stringify(lastRecords)}`);
+}
