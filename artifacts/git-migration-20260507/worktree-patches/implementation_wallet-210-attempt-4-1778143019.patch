+async function waitForWalletRecord(baseUrl: string, walletId: string, dataType: string): Promise<WalletRecord> {
+  const deadline = Date.now() + 15_000;
+  let records: WalletRecord[] = [];
+  while (Date.now() < deadline) {
+    const data = await apiJson<WalletRecordsResponse>(baseUrl, "GET", `/wallets/${walletId}/records`);
+    records = data.records;
+    const record = records.find((item) => item.data_type === dataType);
+    if (record) return record;
+    await delay(100);
+  }
+  throw new Error(`Timed out waiting for ${dataType} record. Saw: ${JSON.stringify(records)}`);
+}
+
+async function waitForGrantReceipt(
+  baseUrl: string,
+  walletId: string,
+  audienceDid: string,
+  expectedStatus = "active"
+): Promise<GrantReceiptRecord> {
+  const deadline = Date.now() + 15_000;
+  let receipts: GrantReceiptRecord[] = [];
+  while (Date.now() < deadline) {
+    const query = new URLSearchParams({ audience_did: audienceDid, status: "all" });
+    const data = await apiJson<GrantReceiptsResponse>(baseUrl, "GET", `/wallets/${walletId}/grant-receipts?${query}`);
+    receipts = data.receipts;
+    const receipt = receipts.find((item) => item.status === expectedStatus);
+    if (receipt) return receipt;
+    await delay(100);
+  }
+  throw new Error(`Timed out waiting for ${expectedStatus} grant receipt. Saw: ${JSON.stringify(receipts)}`);
+}
+
+async function waitForAuditActions(baseUrl: string, walletId: string, expectedActions: string[]): Promise<string[]> {
+  const deadline = Date.now() + 15_000;
+  let actions: string[] = [];
+  while (Date.now() < deadline) {
+    const audit = await apiJson<{ events: Array<{ action: string }> }>(
+      baseUrl,
+      "GET",
+      `/wallets/${walletId}/audit`
+    );
+    actions = audit.events.map((event) => event.action);
+    if (expectedActions.every((action) => actions.includes(action))) return actions;
+    await delay(100);
+  }
+  throw new Error(`Timed out waiting for audit actions ${expectedActions.join(", ")}. Saw: ${actions.join(", ")}`);
+}
