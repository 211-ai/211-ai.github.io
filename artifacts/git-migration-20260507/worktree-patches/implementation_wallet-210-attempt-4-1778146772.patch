+async function apiJsonResponse<T>(
+  baseUrl: string,
+  method: string,
+  route: string,
+  payload?: unknown
+): Promise<{ body: T; status: number }> {
+  const response = await fetch(new URL(route, baseUrl), {
+    body: payload === undefined ? undefined : JSON.stringify(payload),
+    headers: payload === undefined ? undefined : { "content-type": "application/json" },
+    method
+  });
+  return {
+    body: (await response.json().catch(() => ({}))) as T,
+    status: response.status
+  };
+}
+
+async function waitForWalletRecords(
+  baseUrl: string,
+  walletId: string,
+  dataTypes: string[]
+): Promise<WalletRecordDetails[]> {
+  const deadline = Date.now() + 15_000;
+  let records: WalletRecordDetails[] = [];
+  while (Date.now() < deadline) {
+    const response = await apiJson<{ records: WalletRecordDetails[] }>(baseUrl, "GET", `/wallets/${walletId}/records`);
+    records = response.records;
+    if (dataTypes.every((dataType) => records.some((record) => record.data_type === dataType))) {
+      return records;
+    }
+    await delay(100);
+  }
+  throw new Error(`Wallet records did not include ${dataTypes.join(", ")}: ${JSON.stringify(records)}`);
+}
