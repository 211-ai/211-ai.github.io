+async function waitForFirstRecord(baseUrl: string, walletId: string, dataType: string): Promise<WalletRecord> {
+  let record: WalletRecord | undefined;
+  await expect
+    .poll(async () => {
+      const records = await apiJson<{ records: WalletRecord[] }>(
+        baseUrl,
+        "GET",
+        `/wallets/${walletId}/records?data_type=${dataType}`
+      );
+      record = records.records[0];
+      return Boolean(record);
+    })
+    .toBe(true);
+  if (!record) throw new Error(`No ${dataType} record was created`);
+  return record;
+}
