+import { ExternalLink, Hash, LocateFixed } from "lucide-react";
+import { Badge, Section, StatusBanner } from "../ui";
+import type {
+  GraphRagFieldConfidence,
+  GraphRagServiceDetailMetadata,
+  GraphRagServiceProvenance,
+  GraphRagSourceSpan,
+} from "../../services/graphRagService";
+
+export function ServiceProvenancePanel({
+  metadata,
+  provenance,
+}: {
+  metadata: GraphRagServiceDetailMetadata;
+  provenance: GraphRagServiceProvenance;
+}) {
+  return (
+    <Section title="Source and provenance">
+      <div className="list-stack">
+        {provenance.warnings.map((warning) => (
+          <StatusBanner key={warning} tone="warning">
+            {warning}
+          </StatusBanner>
+        ))}
+
+        <article className="list-item">
+          <div>
+            <h3>Source URL</h3>
+            {provenance.sourceUrl ? (
+              <p style={{ overflowWrap: "anywhere" }}>
+                <a href={provenance.sourceUrl} rel="noreferrer" target="_blank">
+                  {provenance.sourceUrl}
+                </a>
+              </p>
+            ) : (
+              <p>Source URL not listed</p>
+            )}
+          </div>
+          {provenance.sourceUrl ? <ExternalLink aria-hidden="true" size={20} /> : null}
+        </article>
+
+        <ProvenanceRow icon={<Hash aria-hidden="true" size={16} />} label="Source content CID" value={provenance.sourceContentCid} />
+        <ProvenanceRow icon={<Hash aria-hidden="true" size={16} />} label="Source page CID" value={provenance.sourcePageCid} />
+        <ProvenanceRow label="Build manifest CID" value={metadata.buildManifestCid} />
+        <ProvenanceRow label="Documents artifact CID" value={metadata.documentsArtifactCid} />
+        <ProvenanceRow label="Detail loaded at" value={metadata.loadedAt} />
+        <ProvenanceRow label="Scrape timestamp" value="Not included in the current browser corpus" />
+        <ProvenanceRow label="Corpus document count" value={metadata.documentCount.toLocaleString()} />
+
+        <div className="review-panel">
+          <h3>Source spans</h3>
+          {provenance.sourceSpans.length ? (
+            <div className="list-stack">
+              {provenance.sourceSpans.map((span) => (
+                <SourceSpanCard key={`${span.field}-${span.value}-${span.startOffset ?? "none"}`} span={span} />
+              ))}
+            </div>
+          ) : (
+            <p className="supporting-copy">No exact source spans are available for this record.</p>
+          )}
+        </div>
+
+        <div className="review-panel">
+          <h3>Extraction confidence</h3>
+          {provenance.fieldConfidence.length ? (
+            <div className="list-stack">
+              {provenance.fieldConfidence.map((field) => (
+                <FieldConfidenceRow key={`${field.field}-${field.value}`} field={field} />
+              ))}
+            </div>
+          ) : (
+            <p className="supporting-copy">No extracted fields are available for confidence review.</p>
+          )}
+        </div>
+      </div>
+    </Section>
+  );
+}
+
+function SourceSpanCard({ span }: { span: GraphRagSourceSpan }) {
+  return (
+    <article className="list-item">
+      <div>
+        <div className="badge-row">
+          <Badge>{span.label}</Badge>
+          <Badge tone={confidenceTone(span.confidence)}>{formatConfidence(span.confidence)}</Badge>
+          <Badge>{span.extractionMethod}</Badge>
+        </div>
+        <h3>{span.value}</h3>
+        <p className="supporting-copy" style={{ overflowWrap: "anywhere" }}>
+          {span.excerpt}
+        </p>
+      </div>
+      <span className="badge-row" title="Character offsets in source text">
+        <LocateFixed aria-hidden="true" size={16} />
+        <small>
+          {span.startOffset === null || span.endOffset === null ? "offset n/a" : `${span.startOffset}-${span.endOffset}`}
+        </small>
+      </span>
+    </article>
+  );
+}
+
+function FieldConfidenceRow({ field }: { field: GraphRagFieldConfidence }) {
+  return (
+    <article className="list-item">
+      <div>
+        <h3>{field.label}</h3>
+        <p style={{ overflowWrap: "anywhere" }}>{field.value}</p>
+        <small className="upload-machine-summary">
+          {field.extractionMethod}
+          {field.hasSourceSpan ? " with source span" : " without exact source span"}
+        </small>
+      </div>
+      <Badge tone={confidenceTone(field.confidence)}>{formatConfidence(field.confidence)}</Badge>
+    </article>
+  );
+}
+
+function ProvenanceRow({ icon, label, value }: { icon?: JSX.Element; label: string; value: string }) {
+  return (
+    <article className="list-item">
+      <div>
+        <h3>{label}</h3>
+        <p style={{ overflowWrap: "anywhere" }}>{value || "Not listed"}</p>
+      </div>
+      {icon ?? null}
+    </article>
+  );
+}
+
+function formatConfidence(confidence: number): string {
+  return `${Math.round(confidence * 100)}%`;
+}
+
+function confidenceTone(confidence: number): "success" | "warning" | "neutral" {
+  if (confidence >= 0.8) return "success";
+  if (confidence < 0.65) return "warning";
+  return "neutral";
+}
