+function addStructuredField(
+  document: CorpusDocument,
+  spans: GraphRagSourceSpan[],
+  fieldConfidence: GraphRagFieldConfidence[],
+  field: { field: string; label: string; value: string; confidence: number },
+): void {
+  const value = field.value.trim();
+  if (!value) return;
+
+  const span = findExactSpan(document, field.field, field.label, value, field.confidence, "structured-corpus-field");
+  if (span) {
+    spans.push(span);
+  }
+  fieldConfidence.push({
+    field: field.field,
+    label: field.label,
+    value,
+    confidence: span ? field.confidence : Math.max(0.5, field.confidence - 0.18),
+    extractionMethod: span ? "structured-corpus-field" : "structured-corpus-field-no-span",
+    hasSourceSpan: Boolean(span),
+  });
+}
+
+function addRegexFields(
+  document: CorpusDocument,
+  spans: GraphRagSourceSpan[],
+  fieldConfidence: GraphRagFieldConfidence[],
+  field: { field: string; label: string; pattern: RegExp; confidence: number },
+): void {
+  const matches = [...document.text.matchAll(field.pattern)].slice(0, 4);
+  for (const match of matches) {
+    const value = trimTrailingPunctuation(match[0].replace(/\s+/g, " ").trim());
+    const startOffset = match.index ?? null;
+    if (!value || startOffset === null) continue;
+    spans.push(
+      spanFromOffsets(
+        document,
+        field.field,
+        field.label,
+        value,
+        startOffset,
+        startOffset + match[0].length,
+        field.confidence,
+        "regex-source-span",
+      ),
+    );
+    fieldConfidence.push({
+      field: field.field,
+      label: field.label,
+      value,
+      confidence: field.confidence,
+      extractionMethod: "regex-source-span",
+      hasSourceSpan: true,
+    });
+  }
+}
+
+function addSentenceFields(
+  document: CorpusDocument,
+  spans: GraphRagSourceSpan[],
+  fieldConfidence: GraphRagFieldConfidence[],
+  field: { field: string; label: string; pattern: RegExp; confidence: number },
+): void {
+  for (const sentence of findMatchingSentences(document.text, field.pattern).slice(0, 3)) {
+    spans.push(
+      spanFromOffsets(
+        document,
+        field.field,
+        field.label,
+        sentence.value,
+        sentence.startOffset,
+        sentence.endOffset,
+        field.confidence,
+        "sentence-pattern-source-span",
+      ),
+    );
+    fieldConfidence.push({
+      field: field.field,
+      label: field.label,
+      value: sentence.value,
+      confidence: field.confidence,
+      extractionMethod: "sentence-pattern-source-span",
+      hasSourceSpan: true,
+    });
+  }
+}
+
+function findExactSpan(
+  document: CorpusDocument,
+  field: string,
+  label: string,
+  value: string,
+  confidence: number,
+  extractionMethod: string,
+): GraphRagSourceSpan | null {
+  const startOffset =
+    value.length <= 3
+      ? findShortExactValueOffset(document.text, value)
+      : document.text.toLowerCase().indexOf(value.toLowerCase());
+  if (startOffset < 0) return null;
+  return spanFromOffsets(
+    document,
+    field,
+    label,
+    value,
+    startOffset,
+    startOffset + value.length,
+    confidence,
+    extractionMethod,
+  );
+}
+
+function findShortExactValueOffset(text: string, value: string): number {
+  const match = new RegExp(`\\b${escapeRegExp(value)}\\b`, "i").exec(text);
+  return match?.index ?? -1;
+}
+
+function spanFromOffsets(
+  document: CorpusDocument,
+  field: string,
+  label: string,
+  value: string,
+  startOffset: number,
+  endOffset: number,
+  confidence: number,
+  extractionMethod: string,
+): GraphRagSourceSpan {
+  return {
+    field,
+    label,
+    value,
+    excerpt: excerptAround(document.text, startOffset, endOffset),
+    startOffset,
+    endOffset,
+    confidence,
+    extractionMethod,
+    sourceUrl: document.source_url || undefined,
+    contentCid: document.source_content_cid || undefined,
+    pageCid: document.source_page_cid || undefined,
+  };
+}
+
+function findMatchingSentences(text: string, pattern: RegExp): Array<{ value: string; startOffset: number; endOffset: number }> {
+  const matches: Array<{ value: string; startOffset: number; endOffset: number }> = [];
+  const sentencePattern = /[^.!?\n]+(?:[.!?]+|\n|$)/g;
+  for (const match of text.matchAll(sentencePattern)) {
+    const rawValue = match[0];
+    const startOffset = match.index ?? 0;
+    const valueStartTrimmed = rawValue.length - rawValue.trimStart().length;
+    const value = rawValue.trim().replace(/\s+/g, " ");
+    if (!value || !pattern.test(value)) continue;
+    matches.push({
+      value: truncateText(value, 240),
+      startOffset: startOffset + valueStartTrimmed,
+      endOffset: startOffset + rawValue.length,
+    });
+  }
+  return matches;
+}
+
+function excerptAround(text: string, startOffset: number, endOffset: number, radius = 120): string {
+  const start = Math.max(0, startOffset - radius);
+  const end = Math.min(text.length, endOffset + radius);
+  const prefix = start > 0 ? "..." : "";
+  const suffix = end < text.length ? "..." : "";
+  return `${prefix}${text.slice(start, end).replace(/\s+/g, " ").trim()}${suffix}`;
+}
+
+function uniqueSpans(spans: GraphRagSourceSpan[]): GraphRagSourceSpan[] {
+  const seen = new Set<string>();
+  return spans.filter((span) => {
+    const key = `${span.field}:${span.value.toLowerCase()}:${span.startOffset ?? "none"}`;
+    if (seen.has(key)) return false;
+    seen.add(key);
+    return true;
+  });
+}
+
+function uniqueFieldConfidence(fields: GraphRagFieldConfidence[]): GraphRagFieldConfidence[] {
+  const seen = new Set<string>();
+  return fields.filter((field) => {
+    const key = `${field.field}:${field.value.toLowerCase()}`;
+    if (seen.has(key)) return false;
+    seen.add(key);
+    return true;
+  });
+}
+
+function buildProvenanceWarnings(document: CorpusDocument, spans: GraphRagSourceSpan[]): string[] {
+  const warnings: string[] = [];
+  if (document.text_truncated) {
+    warnings.push("The browser corpus text is truncated, so later source spans may be missing.");
+  }
+  if (!document.source_url) {
+    warnings.push("No source URL is listed for this service record.");
+  }
+  if (!document.source_content_cid || !document.source_page_cid) {
+    warnings.push("One or more source CIDs are missing from this service record.");
+  }
+  if (spans.length === 0) {
+    warnings.push("No exact source spans were found in the local browser corpus text.");
+  }
+  return warnings;
+}
+
+function trimTrailingPunctuation(value: string): string {
+  return value.replace(/[),.;:]+$/g, "");
+}
+
+function escapeRegExp(value: string): string {
+  return value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
+}
+
+function truncateText(value: string, maxLength: number): string {
+  return value.length <= maxLength ? value : `${value.slice(0, maxLength - 3).trim()}...`;
+}
