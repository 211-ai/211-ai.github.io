diff --git a/tmp/211-ai-implementation-worktrees/agent-071-attempt-1-1778025365/wallet_interface/ui/src/agent/tools/serviceDetailTools.ts b/tmp/211-ai-implementation-worktrees/agent-071-attempt-1-1778025365/wallet_interface/ui/src/agent/tools/serviceDetailTools.ts
