+                <div>
+                  <h3>{field.label}</h3>
+                  <p>{field.value}</p>
+                </div>
+                <Badge tone={field.confidence >= 0.9 ? "success" : field.confidence >= 0.8 ? "info" : "warning"}>
+                  {Math.round(field.confidence * 100)}%
+                </Badge>
