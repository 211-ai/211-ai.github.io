FROM node:20-alpine AS build

WORKDIR /app/wallet_interface/ui

ARG VITE_WALLET_API_BASE_URL=same-origin
ENV VITE_WALLET_API_BASE_URL=$VITE_WALLET_API_BASE_URL

COPY wallet_interface/ui/package.json wallet_interface/ui/package-lock.json ./
RUN npm ci

COPY wallet_interface/ui ./
RUN npm run build

FROM nginx:1.27-alpine

COPY wallet_interface/deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY wallet_interface/deploy/runtime-config.template.json /opt/abby/runtime-config.template.json
COPY wallet_interface/deploy/40-runtime-config.sh /docker-entrypoint.d/40-runtime-config.sh
COPY --from=build /app/wallet_interface/ui/dist /usr/share/nginx/html

EXPOSE 8080

