# Local development overrides for running the bridge-backed stack without
# provider credentials or a remote phone-voice backend.

WALLET_SMS_INBOUND_BEARER_TOKEN=local-dev-inbound-secret

IPFS_DATASETS_EMAIL_PROVIDER_KIND=mock
IPFS_DATASETS_SMS_PROVIDER_KIND=mock
IPFS_DATASETS_SMS_TWILIO_FROM_PHONE=+15035550100
IPFS_DATASETS_CALL_PROVIDER_KIND=mock
IPFS_DATASETS_CALL_TWILIO_FROM_PHONE=+15035550100
IPFS_DATASETS_VOICE_REPLY_PROVIDER_KIND=mock
IPFS_DATASETS_VOICE_MOCK_REPLY_TEXT=This is a local mock reply from Abby. Configure a real voice backend when credentials are ready.

# The browser voice UI still expects a remote voice proxy contract. Disable it
# by default in local mock mode unless you wire a dedicated mock proxy.
ABBY_RUNTIME_VOICE_PROXY_ENABLED=false
ABBY_RUNTIME_VOICE_PROXY_BASE_URL=
ABBY_RUNTIME_VOICE_PROXY_INFER_URL=
ABBY_RUNTIME_VOICE_PROXY_TTS_URL=
ABBY_RUNTIME_VOICE_PROXY_STT_URL=