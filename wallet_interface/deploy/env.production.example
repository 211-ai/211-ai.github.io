# Copy this file outside git and replace every placeholder before production use.
# Docker Compose reads it with:
#   docker compose --env-file wallet_interface/deploy/env.production.local \
#     -f wallet_interface/deploy/docker-compose.wallet.yml up -d
# The same prod API can also serve a GitHub Pages sandbox. In that case set
# WALLET_API_CORS_ORIGINS to the exact Pages origin, for example:
# WALLET_API_CORS_ORIGINS=https://endomorphosis.github.io

WALLET_OPS_HEALTH_SHARED_SECRET=replace-with-random-secret
WALLET_OPS_HEALTH_SECRET_REF=secret-manager://replace-with-ops-health-secret-path
# Leave WALLET_API_CORS_ORIGINS unset when nginx fronts both UI and API on
# 211-ai.com, abby.network, or abetterbridgetoyou.com. Set it only for
# split-origin deployments.
WALLET_API_CORS_ORIGINS=
VITE_WALLET_API_BASE_URL=same-origin
ABBY_RUNTIME_WALLET_API_BASE_URL=same-origin
ABBY_RUNTIME_WALLET_ID=
ABBY_RUNTIME_ACTOR_DID=
ABBY_RUNTIME_ISSUER_KEY_HEX=
ABBY_RUNTIME_AUDIENCE_KEY_HEX=
ABBY_RUNTIME_FILECOIN_UPLOAD_URL=/filecoin-upload
ABBY_RUNTIME_FILECOIN_CLIENT_TOKEN=
# Optional browser-side runtime voice proxy overrides. Set these to the same
# remote voice backend as the IPFS_DATASETS_VOICE_PROXY_* bridge settings below
# when you want the website audio UI and inbound phone gateway to share one
# voice service without rebuilding the UI. If these are left unset in the
# bundled wallet-ui container, runtime-config generation falls back to the
# IPFS_DATASETS_VOICE_PROXY_* values below.
ABBY_RUNTIME_VOICE_PROXY_ENABLED=true
ABBY_RUNTIME_VOICE_PROXY_MODEL=IndexTeam/IndexTTS-2-Demo
ABBY_RUNTIME_VOICE_PROXY_BASE_URL=
ABBY_RUNTIME_VOICE_PROXY_INFER_URL=/voice/indextts/infer
ABBY_RUNTIME_VOICE_PROXY_TTS_URL=/voice/indextts/tts
ABBY_RUNTIME_VOICE_PROXY_STT_URL=/voice/hf-whisper/stt
ABBY_RUNTIME_VOICE_PROXY_FALLBACK_INFER_URL=
ABBY_RUNTIME_VOICE_PROXY_FALLBACK_TTS_URL=
ABBY_RUNTIME_VOICE_PROXY_FALLBACK_STT_URL=
ABBY_RUNTIME_VOICE_PROXY_FALLBACK_MODEL=LiquidAI/LFM2.5-Audio-1.5B-proxy
WALLET_HF_WHISPER_MODEL_NAME=openai/whisper-large-v3-turbo
WALLET_HF_WHISPER_BILL_TO=publicus
WALLET_HF_WHISPER_TIMEOUT_SECONDS=45

# Durable wallet repository and encrypted blob storage.
WALLET_REPOSITORY_ROOT=/var/lib/211-ai/wallet-repository
# Recommended first production shape: keep a local primary replica and pin an
# encrypted mirror into IPFS. Reserve raw {"type":"filecoin"} mirrors until
# your deployment can inject a Filecoin-capable runtime backend.
WALLET_STORAGE_CONFIG={"primary":{"type":"local","root":"/var/lib/211-ai/wallet-blobs"},"mirrors":[{"type":"ipfs","pin":true}]}
# Point the API and ops worker at a trusted Kubo HTTP API when using the ipfs
# storage backend in containers. Example for an in-network service: /dns/ipfs/tcp/5001/http
IPFS_DATASETS_PY_ENABLE_IPFS_HTTPAPI=1
IPFS_HOST=/dns/replace-with-kubo-api-host/tcp/5001/http
# Optional upload-bridge override. Set WALLET_IPFS_UPLOAD_BACKEND=mock for
# credential-free local development when you do not want /filecoin-upload to
# resolve a real IPFS backend.
WALLET_IPFS_UPLOAD_BACKEND=
# Default to the wallet API's same-origin CID proxy so proof-bundle and upload
# links do not depend on public gateway availability. Override this only when
# you intentionally want a public gateway URL in API responses.
WALLET_IPFS_PUBLIC_GATEWAY_BASE_URL=/ipfs-proxy
# Optional CID allowlist for the same-origin proxy. Leave empty to allow any
# CID the wallet API's configured IPFS backend can fetch, or set a comma-
# separated list to restrict proxy access to approved content IDs.
WALLET_IPFS_PROXY_ALLOWED_CIDS=

# Wallet-scoped AI router proxy. The API exposes /wallets/{wallet_id}/ai-router/*
# and /wallets/{wallet_id}/records/{record_id}/metadata/generate, rate limited
# by wallet CID when present and otherwise by wallet id. Hugging Face hosted
# inference is the default provider for metadata organizer labels.
WALLET_AI_ROUTER_RATE_LIMIT_PER_MINUTE=30
WALLET_AI_ROUTER_RATE_LIMIT_PER_DAY=500
IPFS_DATASETS_PY_HF_API_TOKEN=
HF_TOKEN=
HUGGINGFACEHUB_API_TOKEN=
IPFS_DATASETS_PY_HF_INFERENCE_MODEL=
IPFS_DATASETS_PY_HF_EMBEDDINGS_MODEL=
IPFS_DATASETS_PY_HF_INFERENCE_PROVIDER=auto
IPFS_DATASETS_PY_HF_BILL_TO=publicus

# Same-origin browser voice proxy backed by the IndexTeam IndexTTS ZeroGPU Space.
# If the Space changes its Gradio API name or input order, set
# WALLET_INDEXTTS_API_NAME / WALLET_INDEXTTS_FN_INDEX and
# WALLET_INDEXTTS_DATA_TEMPLATE. The template renders JSON with placeholders
# {text}, {voice_description}, and {reference_audio}.
WALLET_INDEXTTS_SPACE_URL=https://indexteam-indextts-2-demo.hf.space
WALLET_INDEXTTS_API_NAME=gen_single
WALLET_INDEXTTS_FN_INDEX=
WALLET_INDEXTTS_DATA_TEMPLATE=
WALLET_INDEXTTS_HF_TOKEN=
WALLET_INDEXTTS_HF_BILL_TO=publicus
WALLET_INDEXTTS_MODEL_NAME=IndexTeam/IndexTTS-2-Demo
WALLET_INDEXTTS_REFERENCE_AUDIO_PATH=
WALLET_INDEXTTS_REFERENCE_AUDIO_REMOTE_PATH=
WALLET_INDEXTTS_TIMEOUT_SECONDS=180
# Optional private Filecoin Pin sidecar. Keep this behind the wallet API and
# point WALLET_FILECOIN_PIN_ORIGINS at reachable Kubo/libp2p swarm multiaddrs
# that can serve freshly published CIDs to the sidecar.
# Enable the sidecar with: docker compose --profile filecoin-pin --env-file ...
# Set WALLET_FILECOIN_PIN_SERVICE_URL=http://filecoin-pin:3456 when that
# profile is enabled, or WALLET_FILECOIN_PIN_SERVICE_URL=mock for
# credential-free local development. FILECOIN_PIN_NETWORK and
# FILECOIN_PIN_RPC_URL are mutually exclusive; set only one.
WALLET_FILECOIN_PIN_SERVICE_URL=
WALLET_FILECOIN_PIN_ORIGINS=
WALLET_FILECOIN_PIN_BEARER_TOKEN=
WALLET_FILECOIN_PIN_HTTP_HEADER_NAME=
WALLET_FILECOIN_PIN_HTTP_HEADER_VALUE=
WALLET_FILECOIN_PIN_TIMEOUT_SECONDS=30
WALLET_FILECOIN_PIN_MOCK_STATUS=pinned
FILECOIN_PIN_VERSION=0.20.1
FILECOIN_PIN_ACCESS_TOKEN=
FILECOIN_PIN_PRIVATE_KEY=
FILECOIN_PIN_WALLET_ADDRESS=
FILECOIN_PIN_SESSION_KEY=
FILECOIN_PIN_NETWORK=
FILECOIN_PIN_RPC_URL=
FILECOIN_PIN_LOG_LEVEL=info
# For a target IPFS/S3/Filecoin retention topology, record the finalized JSON
# shape in wallet_interface/deploy/storage-retention.example.json evidence.
WALLET_STORAGE_CREDENTIAL_SECRET_REF=secret-manager://replace-with-storage-credential-path
WALLET_STORAGE_RETENTION_POLICY_REF=docs/WALLET_RETENTION_POLICY.md@2026-05-05
WALLET_STORAGE_IPFS_PINNING_POLICY_REF=replace-with-private-ipfs-pinset-policy-id
WALLET_STORAGE_FILECOIN_DEAL_POLICY_REF=replace-with-filecoin-deal-policy-id-or-not-used
WALLET_STORAGE_S3_LIFECYCLE_POLICY_REF=replace-with-s3-lifecycle-policy-id
WALLET_BACKUP_PURGE_POLICY_REF=replace-with-backup-purge-policy-id
WALLET_AUTO_LOAD_REPOSITORY=true
WALLET_AUTO_PERSIST=true

# Ops alert destination.
WALLET_OPS_ALERT_WEBHOOK_URL=https://ops.example.com/hooks/211-wallet
WALLET_OPS_ALERT_ON=error
WALLET_OPS_ALERT_BEARER_TOKEN=replace-with-alert-webhook-token
WALLET_OPS_ALERT_HEADER_NAME=x-wallet-alert-key
WALLET_OPS_ALERT_HEADER_VALUE=replace-with-alert-header-secret
WALLET_OPS_ALERT_SECRET_REF=secret-manager://replace-with-alert-credential-path
WALLET_ALERT_RETENTION_POLICY_REF=replace-with-alert-retention-policy-id

# Missing-person dead-drop email. wallet-api routes through the internal
# messaging bridge by default, and the bridge can then deliver via SMTP or a
# provider webhook.
WALLET_DEAD_DROP_BACKEND=http
WALLET_DEAD_DROP_WEBHOOK_URL=http://sms-bridge:8061/messages/email/outbound
WALLET_DEAD_DROP_BEARER_TOKEN=
WALLET_DEAD_DROP_HTTP_HEADER_NAME=
WALLET_DEAD_DROP_HTTP_HEADER_VALUE=
WALLET_DEAD_DROP_TIMEOUT_SECONDS=20
WALLET_DEAD_DROP_SMTP_HOST=smtp.example.com
WALLET_DEAD_DROP_SMTP_PORT=587
WALLET_DEAD_DROP_SMTP_USE_SSL=false
WALLET_DEAD_DROP_SMTP_STARTTLS=true
WALLET_DEAD_DROP_SMTP_USERNAME=replace-with-smtp-username
WALLET_DEAD_DROP_SMTP_PASSWORD=replace-with-smtp-password
WALLET_DEAD_DROP_FROM_EMAIL=no-reply@211-ai.org

# Email bridge provider settings. Choose `smtp`, `webhook`, or `mock`.
# SMTP can reuse the WALLET_DEAD_DROP_SMTP_* values above.
IPFS_DATASETS_EMAIL_PROVIDER_KIND=smtp
IPFS_DATASETS_EMAIL_PROVIDER_WEBHOOK_URL=
IPFS_DATASETS_EMAIL_PROVIDER_BEARER_TOKEN=
IPFS_DATASETS_EMAIL_PROVIDER_HTTP_HEADER_NAME=
IPFS_DATASETS_EMAIL_PROVIDER_HTTP_HEADER_VALUE=
IPFS_DATASETS_EMAIL_PROVIDER_TIMEOUT_SECONDS=20

# Internal DuckDB-backed SMS bridge. The wallet API sends outbound messages to
# the compose-local bridge, and public Twilio callbacks arrive at
# https://211-ai.com/messaging/providers/twilio/inbound and
# https://211-ai.com/messaging/providers/twilio/status.
WALLET_SMS_BACKEND=http
WALLET_SMS_WEBHOOK_URL=http://sms-bridge:8061/messages/sms/outbound
WALLET_SMS_BEARER_TOKEN=
WALLET_SMS_HTTP_HEADER_NAME=
WALLET_SMS_HTTP_HEADER_VALUE=
WALLET_SMS_TIMEOUT_SECONDS=15
WALLET_SMS_INBOUND_BEARER_TOKEN=replace-with-bridge-inbound-secret
WALLET_SMS_INBOUND_HTTP_HEADER_NAME=
WALLET_SMS_INBOUND_HTTP_HEADER_VALUE=
WALLET_SMS_INBOUND_ACTOR_DID=did:wallet:sms-bridge
IPFS_DATASETS_SMS_BRIDGE_ARCHIVE_EXPORT_ENABLED=false
IPFS_DATASETS_SMS_BRIDGE_ARCHIVE_EXPORT_INTERVAL_SECONDS=3600
IPFS_DATASETS_SMS_BRIDGE_ARCHIVE_EXPORT_ROOT=/var/lib/211-ai/sms-bridge/exports

# SMS bridge provider settings. Choose `twilio`, `webhook`, or `mock`.
IPFS_DATASETS_SMS_PROVIDER_KIND=twilio
IPFS_DATASETS_SMS_PROVIDER_WEBHOOK_URL=
IPFS_DATASETS_SMS_PROVIDER_BEARER_TOKEN=
IPFS_DATASETS_SMS_PROVIDER_HTTP_HEADER_NAME=
IPFS_DATASETS_SMS_PROVIDER_HTTP_HEADER_VALUE=
IPFS_DATASETS_SMS_PROVIDER_TIMEOUT_SECONDS=15
IPFS_DATASETS_SMS_TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
IPFS_DATASETS_SMS_TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
IPFS_DATASETS_SMS_TWILIO_FROM_PHONE=+15035550100
IPFS_DATASETS_SMS_TWILIO_MESSAGING_SERVICE_SID=
IPFS_DATASETS_SMS_TWILIO_STATUS_CALLBACK_URL=https://211-ai.com/messaging/providers/twilio/status
IPFS_DATASETS_SMS_INBOUND_FORWARD_URL=http://wallet-api:8000/messages/sms/inbound
IPFS_DATASETS_SMS_INBOUND_FORWARD_TIMEOUT_SECONDS=15

# Generic phone-agent / voice-call bridge. Point this at a trusted provider
# adapter inside the internal messaging bridge. Public Twilio voice status
# callbacks land at https://211-ai.com/messaging/providers/twilio/voice/status.
WALLET_CALL_BACKEND=http
WALLET_CALL_WEBHOOK_URL=http://sms-bridge:8061/messages/calls/outbound
WALLET_CALL_BEARER_TOKEN=
WALLET_CALL_HTTP_HEADER_NAME=
WALLET_CALL_HTTP_HEADER_VALUE=
WALLET_CALL_TIMEOUT_SECONDS=20

# Voice-call provider settings. Choose `twilio`, `webhook`, or `mock`.
IPFS_DATASETS_CALL_PROVIDER_KIND=twilio
IPFS_DATASETS_CALL_PROVIDER_WEBHOOK_URL=
IPFS_DATASETS_CALL_PROVIDER_BEARER_TOKEN=
IPFS_DATASETS_CALL_PROVIDER_HTTP_HEADER_NAME=
IPFS_DATASETS_CALL_PROVIDER_HTTP_HEADER_VALUE=
IPFS_DATASETS_CALL_PROVIDER_TIMEOUT_SECONDS=20
IPFS_DATASETS_CALL_TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
IPFS_DATASETS_CALL_TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
IPFS_DATASETS_CALL_TWILIO_FROM_PHONE=+15035550100
IPFS_DATASETS_CALL_TWILIO_STATUS_CALLBACK_URL=https://211-ai.com/messaging/providers/twilio/voice/status

# Inbound AI voice gateway. Point your Twilio number or Twilio SIP Domain
# voice webhook at https://211-ai.com/messaging/providers/twilio/voice/inbound
# or https://211-ai.com/messaging/providers/twilio/sip/inbound. Configure the
# remote voice proxy below to the same infer/TTS/STT backend used by the
# website, or set IPFS_DATASETS_VOICE_REPLY_PROVIDER_KIND=mock for
# credential-free phone-gateway development. The wallet-ui runtime config will
# reuse the remote proxy values below when the ABBY_RUNTIME_VOICE_PROXY_*
# overrides above are left blank.
IPFS_DATASETS_VOICE_PUBLIC_BASE_URL=https://211-ai.com/messaging
IPFS_DATASETS_VOICE_REPLY_PROVIDER_KIND=
IPFS_DATASETS_VOICE_MOCK_REPLY_TEXT=
IPFS_DATASETS_VOICE_PROXY_BASE_URL=
IPFS_DATASETS_VOICE_PROXY_INFER_URL=
IPFS_DATASETS_VOICE_PROXY_TTS_URL=
IPFS_DATASETS_VOICE_PROXY_STT_URL=
IPFS_DATASETS_VOICE_PROXY_TIMEOUT_SECONDS=45
IPFS_DATASETS_VOICE_AGENT_NAME=Abby
IPFS_DATASETS_VOICE_SERVICE_NAME=211 AI
IPFS_DATASETS_VOICE_WEBSITE_URL=https://211-ai.com
IPFS_DATASETS_VOICE_SYSTEM_PROMPT_APPEND=
IPFS_DATASETS_VOICE_MAX_TURNS=8

# Production proof verifier.
WALLET_PROOF_MODE=production
WALLET_ALLOW_SIMULATED_PROOFS=false
WALLET_PROOF_BACKEND=http-location-region
WALLET_PROOF_SERVICE_URL=https://verifier.example.com
WALLET_PROOF_VERIFIER_ID=verifier-http-v1
WALLET_PROOF_SYSTEM=groth16
WALLET_PROOF_CIRCUIT_ID=location-region-v1
WALLET_PROOF_PROVE_PATH=/prove/location-region
WALLET_PROOF_DISTANCE_PROVE_PATH=/prove/location-distance
WALLET_PROOF_VERIFY_PATH=/verify
WALLET_PROOF_BEARER_TOKEN=replace-with-proof-service-token
WALLET_PROOF_HTTP_HEADER_NAME=x-wallet-proof-key
WALLET_PROOF_HTTP_HEADER_VALUE=replace-with-proof-header-secret
WALLET_PROOF_CREDENTIAL_SECRET_REF=secret-manager://replace-with-proof-credential-path
WALLET_PROOF_TIMEOUT_SECONDS=30

# Cloudflare Worker / edge origin configuration.
ORIGIN_API_BASE_URL=https://wallet-api.internal.example.com
OPS_HEALTH_SHARED_SECRET=replace-with-same-value-as-wallet-ops-health-shared-secret
CF_ACCESS_CLIENT_ID=replace-with-cloudflare-access-client-id
CF_ACCESS_CLIENT_SECRET=replace-with-cloudflare-access-client-secret
ORIGIN_AUTH_HEADER_NAME=x-wallet-origin-key
ORIGIN_AUTH_HEADER_VALUE=replace-with-origin-header-secret
ORIGIN_AUTH_BEARER_TOKEN=replace-with-origin-bearer-token
