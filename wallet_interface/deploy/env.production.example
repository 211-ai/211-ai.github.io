# Copy this file outside git and replace every placeholder before production use.
# Docker Compose reads it with:
#   docker compose --env-file wallet_interface/deploy/env.production.local \
#     -f wallet_interface/deploy/docker-compose.wallet.yml up -d

WALLET_OPS_HEALTH_SHARED_SECRET=replace-with-random-secret
WALLET_OPS_HEALTH_SECRET_REF=secret-manager://replace-with-ops-health-secret-path

# Durable wallet repository and encrypted blob storage.
WALLET_REPOSITORY_ROOT=/var/lib/211-ai/wallet-repository
WALLET_STORAGE_CONFIG={"primary":{"type":"local","root":"/var/lib/211-ai/wallet-blobs"}}
WALLET_STORAGE_CREDENTIAL_SECRET_REF=secret-manager://replace-with-storage-credential-path
WALLET_AUTO_LOAD_REPOSITORY=true
WALLET_AUTO_PERSIST=true

# Ops alert destination.
WALLET_OPS_ALERT_WEBHOOK_URL=https://ops.example.com/hooks/211-wallet
WALLET_OPS_ALERT_ON=error
WALLET_OPS_ALERT_BEARER_TOKEN=replace-with-alert-webhook-token
WALLET_OPS_ALERT_HEADER_NAME=x-wallet-alert-key
WALLET_OPS_ALERT_HEADER_VALUE=replace-with-alert-header-secret
WALLET_OPS_ALERT_SECRET_REF=secret-manager://replace-with-alert-credential-path

# Production proof verifier.
WALLET_PROOF_MODE=production
WALLET_ALLOW_SIMULATED_PROOFS=false
WALLET_PROOF_BACKEND=http-location-region
WALLET_PROOF_SERVICE_URL=https://verifier.example.com
WALLET_PROOF_VERIFIER_ID=verifier-http-v1
WALLET_PROOF_SYSTEM=groth16
WALLET_PROOF_CIRCUIT_ID=location-region-v1
WALLET_PROOF_PROVE_PATH=/prove/location-region
WALLET_PROOF_DISTANCE_PROVE_PATH=/prove/location-distance
WALLET_PROOF_VERIFY_PATH=/verify
WALLET_PROOF_BEARER_TOKEN=replace-with-proof-service-token
WALLET_PROOF_HTTP_HEADER_NAME=x-wallet-proof-key
WALLET_PROOF_HTTP_HEADER_VALUE=replace-with-proof-header-secret
WALLET_PROOF_CREDENTIAL_SECRET_REF=secret-manager://replace-with-proof-credential-path
WALLET_PROOF_TIMEOUT_SECONDS=30

# Cloudflare Worker / edge origin configuration.
ORIGIN_API_BASE_URL=https://wallet-api.internal.example.com
OPS_HEALTH_SHARED_SECRET=replace-with-same-value-as-wallet-ops-health-shared-secret
CF_ACCESS_CLIENT_ID=replace-with-cloudflare-access-client-id
CF_ACCESS_CLIENT_SECRET=replace-with-cloudflare-access-client-secret
ORIGIN_AUTH_HEADER_NAME=x-wallet-origin-key
ORIGIN_AUTH_HEADER_VALUE=replace-with-origin-header-secret
ORIGIN_AUTH_BEARER_TOKEN=replace-with-origin-bearer-token
