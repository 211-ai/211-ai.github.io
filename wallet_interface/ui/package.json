{
  "name": "@211-ai/abby-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "clean:visual-artifacts": "node -e \"const fs=require('fs'); for (const dir of ['artifacts/ui-screenshots/latest/desktop','artifacts/ui-screenshots/latest/mobile']) fs.rmSync(dir, { recursive: true, force: true })\"",
    "pretest": "npm run clean:visual-artifacts",
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "pretest:visual": "npm run clean:visual-artifacts",
    "test:visual": "playwright test tests/visual-capture.spec.ts",
    "review:visual": "python3 scripts/review_screenshots.py",
    "review:visual:dry-run": "python3 scripts/review_screenshots.py --dry-run",
    "review:tasks": "python3 scripts/generate_refinement_backlog.py",
    "review:prompts": "python3 scripts/generate_agent_prompts.py"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "lucide-react": "^0.468.0",
    "vite": "^6.4.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.1",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.3.3"
  }
}
