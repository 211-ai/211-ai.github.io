{
  "name": "@211-ai/abby-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build --configLoader runner",
    "preview": "vite preview --host 0.0.0.0 --configLoader runner",
    "clean:visual-artifacts": "node scripts/clean_visual_artifacts.cjs",
    "pretest": "npm run clean:visual-artifacts",
    "test": "node scripts/run_playwright_tests.cjs",
    "test:fullstack": "playwright test tests/fullstack-wallet.spec.ts",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "pretest:visual": "npm run clean:visual-artifacts",
    "test:visual": "playwright test tests/visual-capture.spec.ts",
    "review:visual": "python3 scripts/review_screenshots.py",
    "review:visual:dry-run": "python3 scripts/review_screenshots.py --dry-run",
    "review:tasks": "python3 scripts/generate_refinement_backlog.py",
    "review:prompts": "python3 scripts/generate_agent_prompts.py",
    "auth:magic": "node scripts/magic_login_token.cjs"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev45.0",
    "@huggingface/transformers": "^4.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@xenova/transformers": "^2.17.2",
    "apache-arrow": "^17.0.0",
    "lucide-react": "^0.468.0",
    "onnxruntime-web": "^1.25.1",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tesseract.js": "^7.0.0",
    "vite": "^6.4.2"
  },
  "overrides": {
    "onnxruntime-web": "$onnxruntime-web"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.1",
    "@types/node": "^20.10.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.3.3"
  }
}
